{
	"trailingSlash": "auto",
	"routes": [
		{
			"route": "/sw.js",
			"headers": {
				"cache-control": "no-cache, no-store, must-revalidate",
				"pragma": "no-cache",
				"expires": "0"
			}
		},
		{
			"route": "/manifest.webmanifest",
			"headers": {
				"cache-control": "must-revalidate, max-age=0"
			}
		},
		{
			"route": "/images/*",
			"headers": {
				"cache-control": "must-revalidate, max-age=15770000"
			}
		},
		{
			"route": "/api/*",
			"methods": [
				"GET"
			],
			"allowedRoles": [
				"registeredusers",
				"administrator"
			]
		},
		{
			"route": "/api/*",
			"methods": [
				"PUT",
				"POST",
				"PATCH",
				"DELETE"
			],
			"allowedRoles": [
				"administrator"
			]
		},
		{
			"route": "/api/*",
			"allowedRoles": [
				"authenticated"
			]
		}
	],
	"navigationFallback": {
		"rewrite": "index.html",
		"exclude": [
			"/assets/*",
			"/config.js",
			"/images/**/*",
			"/css/*",
			"/sw.js",
			"/manifest.webmanifest",
			"/*.{js,css,png,jpg,svg,ico,json}"
		]
	},
	"mimeTypes": {
		".webmanifest": "application/manifest+json",
		".json": "application/json"
	}
}