{
	"trailingSlash": "auto",
	"routes": [
		{
			"route": "/manifest.webmanifest",
			"headers": {
				"cache-control": "must-revalidate, max-age=0"
			}
		},
		{
			"route": "/images/*",
			"headers": {
				"cache-control": "must-revalidate, max-age=15770000"
			}
		},
		{
			"route": "/api/*",
			"methods": [
				"GET"
			],
			"allowedRoles": [
				"registeredusers"
			]
		},
		{
			"route": "/api/*",
			"methods": [
				"PUT",
				"POST",
				"PATCH",
				"DELETE"
			],
			"allowedRoles": [
				"administrator"
			]
		},
		{
			"route": "/api/*",
			"allowedRoles": [
				"authenticated"
			]
		}
	],
	"navigationFallback": {
		"rewrite": "index.html",
		"exclude": [
			"/assets/*",
			"/config.js",
			"/images/*.{png,jpg,gif}",
			"/css/*",
			"/sw.js",
			"/manifest.webmanifest"
		]
	},
	"mimeTypes": {
		".webmanifest": "application/manifest+json",
		".json": "text/json"
	}
}